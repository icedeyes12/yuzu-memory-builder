# =========================================
# YUZU MEMORY BUILDER - ENVIRONMENT CONFIG
# =========================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real credentials!

# -----------------------------------------
# 1. SUPABASE DATABASE (Source)
# -----------------------------------------
# Get this from Supabase Dashboard > Settings > Database
# Format: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres

# -----------------------------------------
# 2. SUPABASE API (Alternative connection)
# -----------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_or_service_role_key

# -----------------------------------------
# 3. SECURITY KEYS (Required for token generation)
# -----------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET=your_256_bit_secret_here
SECRET_KEY=your_256_bit_secret_here

# -----------------------------------------
# 4. HUGGINGFACE (ONNX Model Download)
# -----------------------------------------
# Optional: Get from huggingface.co/settings/tokens
# Required for private models or rate limit bypass
HF_TOKEN=your_huggingface_token

# -----------------------------------------
# 5. EMBEDDING MODEL CONFIG
# -----------------------------------------
# Options: intfloat/multilingual-e5-large (best, 1024 dim)
#          intfloat/multilingual-e5-base  (fast, 768 dim)
#          BAAI/bge-m3                    (alternative)
MODEL_NAME=intfloat/multilingual-e5-large

# -----------------------------------------
# 6. PROCESSING SETTINGS
# -----------------------------------------
# Batch size for Supabase queries (keep low for free tier)
BATCH_SIZE=100

# Number of parallel workers
MAX_WORKERS=2

# ONNX Runtime threads
ONNX_THREADS=4

# -----------------------------------------
# 7. SAFETY FLAGS
# -----------------------------------------
# Dry run: process without writing to Supabase
DRY_RUN=true

# Validate before migrate: check all data first
VALIDATE_BEFORE_MIGRATE=true

# Skip migration if validation fails
SKIP_MIGRATE_ON_ERROR=true

# -----------------------------------------
# 8. FEATURE TOGGLES
# -----------------------------------------
# Extract semantic memories from messages
ENABLE_SEMANTIC=true

# Apply FSRS (spaced repetition) parameters
ENABLE_FSRS=true

# Generate embeddings (disable for testing)
ENABLE_EMBED=true
