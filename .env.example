# ============================================
# Yuzu Memory Builder - Environment Config
# ============================================

# Supabase (READ-ONLY during export, WRITE during migrate)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Security (copy from yuzu-v2 backend)
JWT_SECRET=your-jwt-secret-here
SECRET_KEY=your-secret-key-here

# Local Storage
LOCAL_DB_PATH=./yuzu_local.duckdb

# ONNX Model
MODEL_NAME=intfloat/multilingual-e5-large
# Alternative: intfloat/multilingual-e5-base (smaller, faster)

# Processing
BATCH_SIZE=50
MAX_WORKERS=2
ENABLE_SEMANTIC=true
ENABLE_FSRS=true

# Safety
DRY_RUN=true
VALIDATE_BEFORE_MIGRATE=true
